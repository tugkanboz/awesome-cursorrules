## Advanced Configuration Options

### Custom Test Environment
```javascript
// jest.config.js
module.exports = {
  testEnvironment: '<rootDir>/custom-test-environment.js',
};

// custom-test-environment.js
const NodeEnvironment = require('jest-environment-node').default;

class CustomEnvironment extends NodeEnvironment {
  async setup() {
    await super.setup();
    this.global.customValue = 'test-value';
  }

  async teardown() {
    await super.teardown();
  }
}

module.exports = CustomEnvironment;
```

### Global Setup and Teardown
```javascript
// jest.config.js
module.exports = {
  globalSetup: '<rootDir>/global-setup.js',
  globalTeardown: '<rootDir>/global-teardown.js',
};

// global-setup.js
module.exports = async () => {
  // Start test database
  global.__DB__ = await startDatabase();
};

// global-teardown.js
module.exports = async () => {
  // Stop test database
  await global.__DB__.stop();
};
```

### Multiple Projects Configuration
```javascript
module.exports = {
  projects: [
    {
      displayName: 'unit',
      testMatch: ['<rootDir>/src/**/*.test.js'],
      testEnvironment: 'node',
    },
    {
      displayName: 'integration',
      testMatch: ['<rootDir>/tests/integration/**/*.test.js'],
      testEnvironment: 'node',
    },
    {
      displayName: 'e2e',
      testMatch: ['<rootDir>/tests/e2e/**/*.test.js'],
      testEnvironment: 'jsdom',
    },
  ],
};
```

## Code Coverage Configuration

### Detailed Coverage Settings
```javascript
module.exports = {
  collectCoverage: true,
  collectCoverageFrom: [
    'src/**/*.{js,jsx,ts,tsx}',
    '!src/**/*.d.ts',
    '!src/**/*.test.{js,jsx,ts,tsx}',
    '!src/**/*.spec.{js,jsx,ts,tsx}',
    '!src/**/__tests__/**',
    '!src/**/__mocks__/**',
    '!src/**/index.{js,ts}',
