## Mocking File System (Node.js)

```javascript
import fs from 'fs';

jest.mock('fs');

describe('File operations', () => {
  test('should read file', () => {
    const mockData = 'file content';
    fs.readFileSync.mockReturnValue(mockData);

    const content = fs.readFileSync('test.txt', 'utf8');

    expect(content).toBe('file content');
    expect(fs.readFileSync).toHaveBeenCalledWith('test.txt', 'utf8');
  });

  test('should write file', () => {
    fs.writeFileSync.mockImplementation(() => {});

    fs.writeFileSync('test.txt', 'new content');

    expect(fs.writeFileSync).toHaveBeenCalledWith('test.txt', 'new content');
  });
});
```

## Mock Call Inspection

### Analyzing Mock Calls
```javascript
describe('Mock call inspection', () => {
  test('should inspect all calls', () => {
    const mockFn = jest.fn();

    mockFn('first', 1);
    mockFn('second', 2);
    mockFn('third', 3);

    // Access all calls
    expect(mockFn.mock.calls).toEqual([
      ['first', 1],
      ['second', 2],
      ['third', 3],
    ]);

    // Access specific call
    expect(mockFn.mock.calls[0][0]).toBe('first');
    expect(mockFn.mock.calls[1][1]).toBe(2);

    // Last call
    expect(mockFn.mock.lastCall).toEqual(['third', 3]);
  });

  test('should inspect return values', () => {
    const mockFn = jest.fn()
      .mockReturnValueOnce('a')
      .mockReturnValueOnce('b');

    mockFn();
    mockFn();

    expect(mockFn.mock.results).toEqual([
      { type: 'return', value: 'a' },
      { type: 'return', value: 'b' },
    ]);
  });

  test('should track instances', () => {
    const MockClass = jest.fn();
    const instance1 = new MockClass();
    const instance2 = new MockClass();

    expect(MockClass.mock.instances).toHaveLength(2);
    expect(MockClass.mock.instances[0]).toBe(instance1);
    expect(MockClass.mock.instances[1]).toBe(instance2);
  });
});
```

## Advanced Mocking Patterns

### Conditional Mocking
```javascript
const mockFetch = jest.fn((url) => {
  if (url.includes('/users/1')) {
    return Promise.resolve({
      ok: true,
      json: async () => ({ id: 1, name: 'John' }),
    });
  }

  if (url.includes('/users/2')) {
    return Promise.resolve({
      ok: true,
      json: async () => ({ id: 2, name: 'Jane' }),
    });
  }

  return Promise.resolve({
    ok: false,
    status: 404,
  });
});

global.fetch = mockFetch;

test('should handle different endpoints', async () => {
  const user1 = await fetch('/users/1').then(r => r.json());
  const user2 = await fetch('/users/2').then(r => r.json());

  expect(user1.name).toBe('John');
  expect(user2.name).toBe('Jane');
});
```

### Chained Mocking
```javascript
describe('Chained API calls', () => {
  test('should mock chained methods', () => {
    const mockDb = {
      select: jest.fn().mockReturnThis(),
      from: jest.fn().mockReturnThis(),
      where: jest.fn().mockReturnThis(),
      execute: jest.fn().mockResolvedValue([{ id: 1 }]),
    };

    const query = mockDb
      .select('*')
      .from('users')
      .where('id', 1)
      .execute();

    expect(mockDb.select).toHaveBeenCalledWith('*');
    expect(mockDb.from).toHaveBeenCalledWith('users');
    expect(mockDb.where).toHaveBeenCalledWith('id', 1);
  });
});
```

### Mock Factory Pattern
```javascript
// test-utils/mockFactories.js
export const createMockUser = (overrides = {}) => ({
  id: 1,
  name: 'John Doe',
  email: 'john@example.com',
  role: 'user',
  ...overrides,
});

export const createMockApiResponse = (data, overrides = {}) => ({
  ok: true,
  status: 200,
  data,
  ...overrides,
});

// user.test.js
import { createMockUser, createMockApiResponse } from './test-utils/mockFactories';

describe('User operations', () => {
  test('should process user', () => {
    const user = createMockUser({ name: 'Jane' });
    const response = createMockApiResponse(user);

    expect(response.data.name).toBe('Jane');
  });
});
```

## Clearing and Resetting Mocks

### Clear vs Reset vs Restore
```javascript
describe('Mock cleanup', () => {
  const mockFn = jest.fn();

  beforeEach(() => {
    mockFn.mockReturnValue(42);
    mockFn('test');
  });

  test('clearAllMocks - clears call history', () => {
    jest.clearAllMocks();

    expect(mockFn).not.toHaveBeenCalled();
    expect(mockFn()).toBe(42); // Implementation still exists
  });

  test('resetAllMocks - clears history and implementation', () => {
    jest.resetAllMocks();

    expect(mockFn).not.toHaveBeenCalled();
    expect(mockFn()).toBeUndefined(); // Implementation cleared
  });

  test('restoreAllMocks - restores original implementation', () => {
    const obj = { method: () => 'original' };
    const spy = jest.spyOn(obj, 'method').mockReturnValue('mocked');

    expect(obj.method()).toBe('mocked');

    jest.restoreAllMocks();

    expect(obj.method()).toBe('original');
  });
});
```

### Manual Cleanup
```javascript
describe('Manual cleanup', () => {
  let mockFn;

  beforeEach(() => {
    mockFn = jest.fn();
  });

  afterEach(() => {
    mockFn.mockClear();  // Clear call history
    // or
    mockFn.mockReset();  // Clear history and implementation
    // or
    mockFn.mockRestore(); // Restore original (for spies)
  });

  test('should work independently', () => {
    mockFn('test');
    expect(mockFn).toHaveBeenCalledWith('test');
  });
});
```

## Best Practices

### 1. Clear Mocks Between Tests
```javascript
beforeEach(() => {
  jest.clearAllMocks();
});
```

### 2. Use Specific Assertions
```javascript
// ✅ Good - Specific assertions
expect(mockFn).toHaveBeenCalledWith(expectedArg);
expect(mockFn).toHaveBeenCalledTimes(1);

// ❌ Avoid - Too general
expect(mockFn).toHaveBeenCalled();
```

### 3. Mock at the Right Level
```javascript
// ✅ Good - Mock at module boundary
jest.mock('./api');

// ❌ Avoid - Mocking internal implementation
jest.mock('./utils/helper'); // If it's internal to api
```

### 4. Keep Mocks Simple
```javascript
// ✅ Good - Simple, focused mock
const mockGetUser = jest.fn().mockResolvedValue({ id: 1 });

// ❌ Avoid - Overly complex mock
const mockGetUser = jest.fn((id) => {
  if (id === 1) return Promise.resolve({ id: 1 });
  if (id === 2) return Promise.resolve({ id: 2 });
  // ... many more conditions
});
```

### 5. Document Complex Mocks
```javascript
// Mock the payment gateway with realistic behavior
// - First call fails (simulating network retry)
// - Second call succeeds
const mockPaymentGateway = jest.fn()
  .mockRejectedValueOnce(new Error('Timeout'))
  .mockResolvedValueOnce({ success: true, transactionId: '123' });
```

## Common Pitfalls

### ❌ Forgetting to Clear Mocks
```javascript
// This can cause tests to affect each other
test('first test', () => {
  mockFn('a');
});

test('second test', () => {
  expect(mockFn).toHaveBeenCalledTimes(1); // Might be 2!
});
```

### ❌ Mocking Too Much
```javascript
// Don't mock everything - test real behavior when possible
jest.mock('./math'); // Unnecessary if math is pure functions
```

### ❌ Not Using Type Definitions
```typescript
// ✅ Good - Proper typing
const mockFn = jest.fn<(id: number) => Promise<User>>();

// ❌ Avoid - No types
const mockFn = jest.fn();
```
